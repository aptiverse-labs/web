# Copy to tests/e2e/.env (gitignored) and fill in.
#
# Each role gets its own test account. The suite stores their NextAuth
# session cookies separately in .auth/<role>.json and grep-filters
# scenarios by role tag (@student / @parent / @teacher / @tutor).
#
# All four accounts share the same password by convention to keep this
# tidy — tighten in CI if needed.

E2E_PASSWORD=

E2E_STUDENT_EMAIL=
E2E_PARENT_EMAIL=
E2E_TEACHER_EMAIL=
E2E_TUTOR_EMAIL=

# Optional overrides — defaults match local dev.
E2E_UI_BASE_URL=http://localhost:3000
E2E_API_BASE_URL=http://localhost:5100
