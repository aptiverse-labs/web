# Copy to tests/e2e/.env (gitignored) and fill in.
# These credentials are used by the E2E suite to sign in as a real user.
# Use a dedicated test account — the suite creates and deletes content.

E2E_TEST_EMAIL=
E2E_TEST_PASSWORD=

# Optional overrides — defaults match local dev.
E2E_UI_BASE_URL=http://localhost:3000
E2E_API_BASE_URL=http://localhost:5100
