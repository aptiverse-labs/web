# Copy to tests/e2e/.env (gitignored) and fill in.
#
# Only two values are strictly required — the student email and the
# shared password. parent / teacher / tutor accounts default to the
# shared test addresses listed below. Override any of them with the
# matching E2E_<ROLE>_EMAIL var if you ever need to.

E2E_STUDENT_EMAIL=
E2E_PASSWORD=

# Optional explicit overrides — defaults are baked in.
# E2E_PARENT_EMAIL=parent.test@gmail.com
# E2E_TEACHER_EMAIL=teacher.test@gmail.com
# E2E_TUTOR_EMAIL=tutor.test@gmail.com

# Legacy single-account convention is still honoured:
#   E2E_TEST_EMAIL    falls through to E2E_STUDENT_EMAIL
#   E2E_TEST_PASSWORD falls through to E2E_PASSWORD

# Optional base-URL overrides — defaults match local dev.
E2E_UI_BASE_URL=http://localhost:3000
E2E_API_BASE_URL=http://localhost:5100
