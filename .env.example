# Copy to .env.local and fill in. Restart `npm run dev` after editing.
# (.env.local is gitignored; this template is committed.)

# --- NextAuth ---
# NEXTAUTH_URL: the web app's own origin (dev = http://localhost:3000).
NEXTAUTH_URL=http://localhost:3000
# NEXTAUTH_SECRET: any 32+ byte random string. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
NEXTAUTH_SECRET=

# --- .NET API base URL (the host that serves /api/auth/*) ---
NEXT_PUBLIC_API_URL=http://localhost:5100

# --- Google OAuth ("Continue with Google") ---
# Google Cloud Console > APIs & Services > Credentials > Create OAuth client ID
# > Web application. Add this Authorized redirect URI exactly:
#   http://localhost:3000/api/auth/callback/google
# (add your prod origin's /api/auth/callback/google too when you deploy).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Analytics and conversion tracking ---
#
# Nothing here is required to run the app. Leave every value blank and the
# consent banner still works, the funnel still logs in debug mode, and the
# advertising tag simply never loads.
#
# NEXT_PUBLIC_META_PIXEL_ID: the numeric pixel id from Meta Events Manager
# (Business Settings > Data Sources > Datasets). NOT a secret, it ships in the
# page by design, but it is still an env var so a preview deploy does not
# pollute production's numbers. The API needs the SAME id as META_PIXEL_ID so
# the browser events and the server events land on one dataset.
# The pixel only loads after the visitor presses Accept.
NEXT_PUBLIC_META_PIXEL_ID=

# NEXT_PUBLIC_VERCEL_CUSTOM_EVENTS: set to 1 ONLY once the Vercel project is on
# a Pro plan. Vercel Web Analytics counts page views on every plan, but custom
# events are a Pro feature, so on Hobby this stays blank and the funnel counts
# live in Meta Events Manager instead. Page views work either way; there is no
# id or key to set for them, Vercel serves the script from our own origin.
NEXT_PUBLIC_VERCEL_CUSTOM_EVENTS=

# NEXT_PUBLIC_ANALYTICS_DEBUG: set to 1 to log every funnel event to the
# console with the consent state that was applied to it. Local only. This is
# how you verify the gate without a network tab.
NEXT_PUBLIC_ANALYTICS_DEBUG=
