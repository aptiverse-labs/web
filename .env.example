# Copy to .env.local and fill in. Restart `npm run dev` after editing.
# (.env.local is gitignored; this template is committed.)

# --- NextAuth ---
# NEXTAUTH_URL: the web app's own origin (dev = http://localhost:3000).
NEXTAUTH_URL=http://localhost:3000
# NEXTAUTH_SECRET: any 32+ byte random string. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
NEXTAUTH_SECRET=

# --- .NET API base URL (the host that serves /api/auth/*) ---
NEXT_PUBLIC_API_URL=http://localhost:5100

# --- Google OAuth ("Continue with Google") ---
# Google Cloud Console > APIs & Services > Credentials > Create OAuth client ID
# > Web application. Add this Authorized redirect URI exactly:
#   http://localhost:3000/api/auth/callback/google
# (add your prod origin's /api/auth/callback/google too when you deploy).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
